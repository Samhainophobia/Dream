local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Teams = game:GetService("Teams") 
local ServerScriptService = game:GetService("ServerScriptService")
local BadgeService = game:GetService("BadgeService")
local DataStoreService = game:GetService("DataStoreService") -- Added for saving data

local ScarlettShardService = require(ServerScriptService:WaitForChild("ScarlettShardService"))


local FIRST_DREAM_BADGE_ID = 4312280043259056 
local DREAM_DATA_STORE_KEY = "FrozenSoulData_v1"


local DreamDataStore = DataStoreService:GetDataStore(DREAM_DATA_STORE_KEY)


local originalLightingState = {}

local function saveLightingState()
	originalLightingState.Ambient = Lighting.Ambient
	originalLightingState.OutdoorAmbient = Lighting.OutdoorAmbient
	originalLightingState.ColorShift_Bottom = Lighting.ColorShift_Bottom
	originalLightingState.ColorShift_Top = Lighting.ColorShift_Top
	originalLightingState.Brightness = Lighting.Brightness
	originalLightingState.ClockTime = Lighting.ClockTime
	originalLightingState.GeographicLatitude = Lighting.GeographicLatitude
	originalLightingState.FogColor = Lighting.FogColor
	originalLightingState.FogEnd = 500 
	originalLightingState.FogStart = 50
end

local function restoreLightingState()
	Lighting.Ambient = originalLightingState.Ambient
	Lighting.OutdoorAmbient = originalLightingState.OutdoorAmbient
	Lighting.ColorShift_Bottom = originalLightingState.ColorShift_Bottom
	Lighting.ColorShift_Top = originalLightingState.ColorShift_Top
	Lighting.Brightness = originalLightingState.Brightness
	Lighting.ClockTime = originalLightingState.ClockTime
	Lighting.GeographicLatitude = originalLightingState.GeographicLatitude
	Lighting.FogColor = originalLightingState.FogColor
	Lighting.FogEnd = originalLightingState.FogEnd
	Lighting.FogStart = originalLightingState.FogStart
end

Lighting.FogStart = 50
Lighting.FogEnd = 500
saveLightingState()

local function setupLeaderstats(player)
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local souls = Instance.new("IntValue")
	souls.Name = "Souls"
	souls.Value = 0
	souls.Parent = leaderstats

	local dreams = Instance.new("IntValue")
	dreams.Name = "Dreams"
	dreams.Value = 0 
	dreams.Parent = leaderstats


	local playerKey = "Player_" .. player.UserId
	local success, savedDreamsValue = pcall(function()
		return DreamDataStore:GetAsync(playerKey)
	end)

	if success and savedDreamsValue then
		dreams.Value = savedDreamsValue
		print("DataStore: Successfully loaded " .. tostring(savedDreamsValue) .. " Dreams for " .. player.Name)
	else
		if not success then
			warn("DataStore Error: Failed to fetch Dreams data for " .. player.Name)
		end
	end
end

local function savePlayerData(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return end

	local dreamsValue = leaderstats:FindFirstChild("Dreams")
	if not dreamsValue then return end

	local playerKey = "Player_" .. player.UserId
	local success, err = pcall(function()
		DreamDataStore:SetAsync(playerKey, dreamsValue.Value)
	end)

	if success then
		print("DataStore: Successfully saved " .. tostring(dreamsValue.Value) .. " Dreams for " .. player.Name)
	else
		warn("DataStore Error: Could not save data for " .. player.Name .. " -> " .. tostring(err))
	end
end

-- Hook up Player Connection and Core Lifecycle Handlers
Players.PlayerAdded:Connect(setupLeaderstats)
Players.PlayerRemoving:Connect(savePlayerData)

-- Fallback mechanism for sudden server closures or crashes
game:BindToClose(function()
	for _, player in ipairs(Players:GetPlayers()) do
		savePlayerData(player)
	end
end)

_G.LoadDream = function(dreamFolder, playerPositions, lightingSettings)
	if not dreamFolder then warn("MapManager: Map argument invalid!"); return end

	-- Clean up old actors from previous runs
	local activeMap = workspace:FindFirstChild("ActiveMap")
	if activeMap then activeMap:Destroy() end

	-- Re-anchor lighting cleanly to start the sequence
	restoreLightingState()

	local newMap = dreamFolder:Clone()
	newMap.Name = "ActiveMap"
	newMap.Parent = workspace

	if lightingSettings then
		for settingName, targetValue in pairs(lightingSettings) do
			local success = pcall(function()
				Lighting[settingName] = targetValue
			end)
			if not success then warn("MapManager: Invalid lighting key -> " .. tostring(settingName)) end
		end
	end

	-- Distribute progression milestones and awards across all actors in the match
	for _, player in pairs(Players:GetPlayers()) do
		local stats = player:FindFirstChild("leaderstats")
		if stats then 
			stats.Souls.Value += 1
			stats.Dreams.Value += 1 
		end


		task.spawn(function()
			local badgeSuccess, hasBadge = pcall(function()
				return BadgeService:UserHasBadgeAsync(player.UserId, FIRST_DREAM_BADGE_ID)
			end)

			if badgeSuccess and not hasBadge then
				pcall(function()
					BadgeService:AwardBadge(player.UserId, FIRST_DREAM_BADGE_ID)
				end)
			end
		end)
	end

	-- Relocate characters to designated map markers
	for _, spawnNode in pairs(playerPositions) do
		local matchingPlayer = Players:FindFirstChild(spawnNode.Name)
		if matchingPlayer and matchingPlayer.Character then
			local rootPart = matchingPlayer.Character:FindFirstChild("HumanoidRootPart")
			if rootPart then
				rootPart.CFrame = spawnNode.CFrame + Vector3.new(0, 3, 0)
			end
		end
	end

	-- Notify supporting systems that the dream transition sequence has finished
	local transitionComplete = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("TransitionComplete")
	if transitionComplete then
		transitionComplete:FireAllClients()
	end
end

_G.WakeUp = function()
	local activeMap = workspace:FindFirstChild("ActiveMap")
	if activeMap then activeMap:Destroy() end

	restoreLightingState()

	-- Clean up shard configurations to allow fresh staging
	ScarlettShardService.ClearAllShards()

	for _, player in pairs(Players:GetPlayers()) do
		player.Team = Teams:WaitForChild("Spawn")
		player:LoadCharacter()
	end

	print("MapManager: Server successfully reset back to Awake/Spawn state.")
end
